<Window x:Class="GStreamerDotNetTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="450" Width="800"
        Loaded="MainWindow_Loaded" Closing="MainWindow_Closing">
    <Grid>
    <TabControl Grid.Row="1">
        <TabItem Header="streameing">
            <Grid Background="#FFE5E5E5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                    <Button x:Name="btnM1Play" Content="Monitor 1 Play" Width="90" Margin="5,0" Click="btnMonitorPlay_Click"/>
                    <Button x:Name="btnM2Play" Content="Monitor 2 Play" Width="90" Margin="5,0" Click="btnMonitorPlay_Click"/>
                    <Button x:Name="btnM3Play" Content="Monitor 3 Play" Width="90" Margin="5,0" Click="btnMonitorPlay_Click"/>
                    <Button x:Name="btnM4Play" Content="Monitor 4 Play" Width="90" Margin="5,0" Click="btnMonitorPlay_Click"/>
                    <Button x:Name="btnPlay" Content="Server Play" Width="80" Margin="5,0" Click="btnPlay_Click"/>
                    <Button x:Name="btnStop" Content="Server Stop" Width="80" Click="btnStop_Click"/>
                </StackPanel>

                <!--<Button Grid.Row="1"/>-->
                <Border x:Name="videoContainer" Grid.Row="1" Margin="5" BorderBrush="Black" BorderThickness="1" Background="Black" HorizontalAlignment="Stretch"/>
            </Grid>

        </TabItem>
        <TabItem Header="settings">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <Grid Height="30" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Server IP:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Name="Textbox_serverIP" Grid.Column="1" />
                        </Grid>
                        <Grid Height="30" >
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Num of stream:" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2"/>
                            <TextBox Name="Textbox_numofstreamer" Grid.Column="1" TextChanged="Textbox_numofstreamer_TextChanged" Height="30" />
                        </Grid>
                    </StackPanel>
                    <TabControl Grid.Row="1" x:Name="StreamSettingsTab"/>
                    <Button Grid.Row="2" Content="save setting" HorizontalAlignment="Left" Margin="10,10,0,10" VerticalAlignment="Center" Width="75" Click="BtnSaveSetting_Click"/>
                </Grid>
            </TabItem>
          
        </TabControl>
    
       
    </Grid>
</Window>
